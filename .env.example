# China 2026 Command Center — environment template.
# Public placeholders only. NEVER commit live values. Put production values in
# Vercel project environment variables; local values in an ignored .env.local.
#
# The app is fully functional as a public/static app with NONE of these set
# (demo data active, admin page reports "Not configured"). These enable the
# future authenticated Supabase tier — see docs/SUPABASE.md and
# docs/PRIVATE_TIER.md. Mohammed must provide the real values in Vercel.

# --- Public tier (browser + server). Safe to expose; anon key is public. ---
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-placeholder

# --- Server only. NEVER exposed to the browser or static bundle. ---
# Used by the admin health check and future server-side maintenance.
SUPABASE_SERVICE_ROLE_KEY=server-service-role-placeholder

# --- CLI / scripts metadata (optional). ---
SUPABASE_PROJECT_REF=demo-project-ref
SUPABASE_DB_PASSWORD=local-development-placeholder
